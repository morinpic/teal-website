# microCMS Configuration
# These are server-side only environment variables (never use NEXT_PUBLIC_ prefix)

# microCMS service domain (without .microcms.io)
# Example: If your microCMS URL is https://your-service.microcms.io, use "your-service"
MICROCMS_SERVICE_DOMAIN=your-service-name

# microCMS API key (Management API or GET-only key)
# Find this in microCMS dashboard -> API Keys
MICROCMS_API_KEY=your-api-key
